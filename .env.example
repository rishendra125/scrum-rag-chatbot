# Copy this file to .env and fill in real values.
# Nothing here is required to run the pipeline offline (local TF-IDF +
# dry-run LLM) -- these only matter once you switch to real backends.

# "local" (default, offline, TF-IDF) or "api" (real semantic embeddings)
EMBEDDING_BACKEND=local
OPENAI_API_KEY=

# "dry_run" (default, no model call) or "anthropic"
LLM_BACKEND=dry_run
ANTHROPIC_API_KEY=
